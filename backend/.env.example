# =============================================================
# Variáveis de Ambiente — Sistema de Contrato de Impressoras
# Copie para .env e ajuste conforme seu ambiente.
# NUNCA comite o arquivo .env no repositório!
# =============================================================

# --- Banco de Dados ---
# PostgreSQL (produção):
DATABASE_URL=postgresql+asyncpg://postgres:senha@localhost:5432/contrato_impressoras

# SQLite (desenvolvimento — descomente e comente a linha acima):
# DATABASE_URL=sqlite+aiosqlite:///./contrato_impressoras.db

# Banco síncrono para o Alembic (migrações)
# PostgreSQL:
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:senha@localhost:5432/contrato_impressoras
# SQLite:
# SYNC_DATABASE_URL=sqlite:///./contrato_impressoras.db

# --- Autenticação JWT ---
# Gere com: openssl rand -hex 32
SECRET_KEY=TROQUE_POR_UMA_CHAVE_SEGURA_DE_64_CARACTERES_HEX
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480   # 8 horas

# --- Active Directory ---
AD_SERVER=10.10.10.10
AD_PORT=389
AD_USE_SSL=false
AD_DOMAIN=organizacao.mil.br
AD_BASE_DN=DC=organizacao,DC=mil,DC=br
# Conta de serviço para busca no AD (somente leitura)
AD_BIND_USER=CN=svc-sistema,OU=Servicos,DC=organizacao,DC=mil,DC=br
AD_BIND_PASSWORD=SenhaContaServico

# --- SNMP ---
SNMP_COMMUNITY=public
SNMP_PORT=161
SNMP_TIMEOUT=5
SNMP_RETRIES=2

# --- Armazenamento de Arquivos ---
UPLOAD_DIR=./uploads   # Pasta para documentos da comissão

# --- Configurações da Aplicação ---
APP_NAME="Sistema de Contrato de Impressoras"
APP_ENV=development    # development | production
DEBUG=true
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
