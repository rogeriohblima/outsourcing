# =============================================================
# .env — Variáveis de ambiente para o Docker Compose
# Copie para .env e ajuste antes de executar o docker compose up
# NUNCA comite este arquivo com valores reais!
# =============================================================

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=contrato_impressoras
POSTGRES_USER=sci_user
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE

# ── Aplicação ─────────────────────────────────────────────────
# Gere com: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=TROQUE_POR_CHAVE_HEX_DE_64_CARACTERES
APP_ENV=production
DEBUG=false

# ── Active Directory ──────────────────────────────────────────
AD_SERVER=10.10.10.10
AD_PORT=389
AD_DOMAIN=organizacao.mil.br
AD_BASE_DN=DC=organizacao,DC=mil,DC=br
AD_BIND_USER=CN=svc-sci,OU=Servicos,DC=organizacao,DC=mil,DC=br
AD_BIND_PASSWORD=SenhaContaServico

# ── SNMP ──────────────────────────────────────────────────────
SNMP_COMMUNITY=public
